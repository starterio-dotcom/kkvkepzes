{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "moodle",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "moodle-b",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-p", "kkvkepzes_b", "--env-file", ".env.b", "up"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "web-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "start"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
